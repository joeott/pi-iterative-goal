# pi-iterative-goal local model-provider environment.
# Copy to .env, chmod 600, and fill real values locally. Never commit .env.
# Placeholder values only.

# Model provider tokens
ANTHROPIC_API_KEY=REPLACE_ME
OPENAI_API_KEY=REPLACE_ME
OPENROUTER_API_KEY=REPLACE_ME
GEMINI_API_KEY=REPLACE_ME
MISTRAL_API_KEY=REPLACE_ME
XAI_API_KEY=REPLACE_ME
DEEPSEEK_API_KEY=REPLACE_ME
GROQ_API_KEY=REPLACE_ME

# Evaluation/tracing providers
PINECONE_API_KEY=REPLACE_ME
LANGCHAIN_API_KEY=REPLACE_ME
LANGSMITH_API_KEY=REPLACE_ME

# Direct Z.ai GLM 5.2 endpoint
ZAI_API_KEY=REPLACE_ME
ZAI_API_BASE_URL=https://api.z.ai/api/coding/paas/v4
ZAI_DEFAULT_MODEL=glm-5.2
ZAI_DEFAULT_VISION_MODEL=glm-5.2v

# AWS account split.
# The control account owns payments/provider billing. The project account is the
# workload sub-account. Secret writes require explicit operator approval flags.
PI_AWS_SECRET_SCOPE=control
PI_AWS_CONTROL_PROFILE=unify-old
PI_AWS_CONTROL_ACCOUNT_ID=371292405073
PI_AWS_PROJECT_PROFILE=api-admin
PI_AWS_PROJECT_ACCOUNT_ID=138881449763
