{
  "name": "pi-iterative-goal",
  "version": "0.1.0",
  "description": "Autonomous supervisor loop Pi extension - never stops until external evaluator returns goal_met=true. Features capability preflight, error classification, safe shell, subagent adapter, and compaction recovery.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "pi": {
    "extensions": [
      "./dist/pi-iterative-goal.js"
    ]
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node scripts/smoke-goal-harness.mjs",
    "smoke": "node scripts/smoke-goal-harness.mjs",
    "lint": "tsc --noEmit",
    "format:check": "node -e \"console.log('format:check: no formatter configured')\"",
    "validate": "npm run test",
    "watch": "tsc -w",
    "env:models": "node scripts/materialize-model-provider-env.mjs",
    "probe:zai": "npm run build && node scripts/probe-zai-glm52.mjs --env-file .env",
    "review:prod-security:readonly": "node scripts/prod-security-review-readonly.mjs --handoff /Users/joe/Downloads/third-party-prod-security-review-handoff-2026-06-29.md --max-iterations 1",
    "review:prod-security:continuous": "node scripts/prod-security-review-readonly.mjs --handoff /Users/joe/Downloads/third-party-prod-security-review-handoff-2026-06-29.md --continuous",
    "evidence:headless": "node scripts/headless-feature-evidence.mjs",
    "evidence:headless:self-compare": "PI_ENABLE_SELF_CAPABILITY_COMPARISON=1 node scripts/headless-feature-evidence.mjs"
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-agent-core": "^0.75.5",
    "@earendil-works/pi-ai": "^0.75.5",
    "@earendil-works/pi-coding-agent": "^0.75.5",
    "@earendil-works/pi-tui": "^0.75.5",
    "typescript": "^5.0.0"
  }
}
