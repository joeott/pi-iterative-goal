{
  "name": "pi-iterative-goal",
  "version": "0.1.0",
  "description": "Autonomous supervisor loop Pi extension - never stops until external evaluator returns goal_met=true. Features capability preflight, error classification, safe shell, subagent adapter, and compaction recovery.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w"
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-agent-core": "^0.75.5",
    "@earendil-works/pi-ai": "^0.75.5",
    "@earendil-works/pi-coding-agent": "^0.75.5",
    "@earendil-works/pi-tui": "^0.75.5",
    "typescript": "^5.0.0"
  }
}
